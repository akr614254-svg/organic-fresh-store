# Copy this file to .env and fill in real values. Never commit .env.

PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.mongodb.net/organic-fresh?retryWrites=true&w=majority

# JWT
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated list of allowed origins for CORS
CLIENT_URL=http://localhost:5173

# Used in later phases (Razorpay + Cloudinary + EmailJS)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Free admin notifications when a new order is placed ---
# Both are optional and independent — leave either blank to skip it.

# 1) Email via any SMTP account.
#    Gmail: use an "App Password" (Google Account > Security > App
#    passwords) — NOT your normal Gmail password. Host: smtp.gmail.com,
#    Port: 465.
#    Or use a free-tier provider like Brevo (smtp-relay.brevo.com, port 587).
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=
ADMIN_EMAIL=

# 2) Telegram bot message (free, instant, no limits).
#    - Message @BotFather on Telegram, send /newbot, follow the prompts —
#      you'll get a token that looks like 123456789:AAExxxxxxxxxxxxxxxxxxxx
#    - Message your new bot once (anything), then visit
#      https://api.telegram.org/bot<token>/getUpdates to find your chat id
#      in the JSON response (message.chat.id).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
